#!/bin/bash

if [ "${#}" -lt 1 ]; then
    >&2 echo "$0 <command to execute outside of container>."
    exit 1
fi

printf -v host_command '%q ' "$@"
host_env=()

while IFS='=' read -r -d '' name value; do
    host_env+=("${name}=${value}")
done < <(env -0)

if [ ! -f "/.dockerenv" ] && [ ! -f "/run/.containerenv" ]; then
    env "${host_env[@]}" bash -lc "${host_command}"
else
    distrobox-host-exec env "${host_env[@]}" bash -lc "${host_command}"
fi
